{
  "name": "TypeRaider",
  "short_name": "TypeRaider",
  "description": "Raid letterforms from images. Type with found glyphs.",
  "start_url": "/typeraider/",
  "display": "standalone",
  "background_color": "#f5f0e8",
  "theme_color": "#c0392b",
  "icons": [
    {
      "src": "icons/icon.svg",
      "type": "image/svg+xml",
      "sizes": "any"
    },
    {
      "src": "icons/icon-192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any maskable"
    },
    {
      "src": "icons/icon-512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/typeraider/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "image",
          "accept": ["image/png", "image/jpeg", "image/webp", "image/gif"]
        }
      ]
    }
  }
}
